{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Joi",
  "version": "0.1.0",
  "identifier": "ai.joi.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Joi",
        "width": 920,
        "height": 680,
        "minWidth": 560,
        "minHeight": 420,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
